# LiteLLM proxy auth. Use any strong value; clients send it as Bearer auth.
LITELLM_MASTER_KEY=sk-local-dev-bedrock-change-me
LITELLM_PORT=4002

# AWS Bedrock. Use either AWS_PROFILE with ~/.aws mounted, or export access keys here.
AWS_REGION_NAME=us-east-1
AWS_REGION=us-east-1
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
