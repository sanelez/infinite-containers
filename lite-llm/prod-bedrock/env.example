# LiteLLM proxy auth. Use a strong value; clients send it as Bearer auth.
# For real production, source this from a secret manager (AWS Secrets Manager,
# SSM Parameter Store, Vault) at deploy time — do NOT commit a real value.
LITELLM_MASTER_KEY=sk-prod-bedrock-change-me
LITELLM_PORT=4003

# AWS Bedrock. Use either AWS_PROFILE with ~/.aws mounted, or export access keys here.
# In real production on EC2/ECS/EKS, prefer instance/task IAM roles over keys.
AWS_REGION_NAME=us-east-1
AWS_REGION=us-east-1
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Local Postgres service used by prod-bedrock/docker-compose.yml.
# Change these BEFORE deploying anywhere beyond your laptop.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-litellm
POSTGRES_DB=litellm
