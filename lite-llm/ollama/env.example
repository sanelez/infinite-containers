# LiteLLM proxy auth. Use any strong value; clients send it as Bearer auth.
LITELLM_MASTER_KEY=sk-local-ollama-change-me
LITELLM_PORT=4001

# Local open-source models used by ollama/docker-compose.yml.
OLLAMA_MODEL_PRIMARY=qwen2.5:0.5b
OLLAMA_MODEL_SECONDARY=smollm2:135m
OLLAMA_PORT=11435

# Local Postgres used by the LiteLLM UI.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-litellm
POSTGRES_DB=litellm
