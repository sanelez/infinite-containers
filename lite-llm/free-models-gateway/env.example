LITELLM_MASTER_KEY=sk-free-models-change-me
LITELLM_PORT=4004
OPEN_WEBUI_PORT=3004

# Postgres used by the LiteLLM admin UI (virtual keys, model store, logs).
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-litellm
POSTGRES_DB=litellm

# Free/free-tier provider keys. Set only the providers you want to route to.
GEMINI_API_KEY=replace-me
GROQ_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me
HUGGINGFACE_API_KEY=replace-me
CLOUDFLARE_API_TOKEN=replace-me
CLOUDFLARE_ACCOUNT_ID=replace-me
